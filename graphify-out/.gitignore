# Machine-local graphify state — regenerated per machine, NOT portable.
# Only the shared graph artifacts (graph.json, GRAPH_REPORT.md,
# .graphify_labels.json) are committed so contributors/sessions can query
# without rebuilding. Everything below is local and must stay untracked:

# Interactive HTML viewer — generated by graphify (not hand-maintained
# source), regenerated with different content on every build, and used only
# by humans (sessions query graph.json / read GRAPH_REPORT.md). Kept out of
# git to avoid committing unmaintainable generated markup.
graph.html

# Absolute paths to this machine's repo root and python interpreter.
.graphify_root
.graphify_python

# Local token/cost accounting for graph builds.
cost.json

# Incremental-build state: keyed by absolute paths + local mtimes, so it is
# stale on any other checkout and would only cause churn/conflicts.
manifest.json

# Version-pinned AST build cache — regenerable, large, and churny.
cache/
